# Database (Neon PostgreSQL)
# Opprett gratis database på https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.eu-west-1.aws.neon.tech/regnskapsbruker?sslmode=require

# NextAuth.js
# Generer med: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your-secret-here

# Resend (e-post)
# Opprett konto på https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=Regnskapsbruker <noreply@regnskapsbruker.no>

# App URL (brukes i e-postlenker)
NEXT_PUBLIC_APP_URL=http://localhost:3000
